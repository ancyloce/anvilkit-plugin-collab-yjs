{
	"extends": "@anvilkit/typescript-config/react-library-bundler.json",
	"compilerOptions": {
		"lib": ["ES2022", "DOM"],
		"outDir": "dist",
		"rootDir": "src",
		"types": ["react", "react-dom", "node"]
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": [
		"node_modules",
		"dist",
		"src/**/*.test.ts",
		"src/**/*.test.tsx",
		"src/**/*.spec.ts",
		"src/**/*.spec.tsx",
		"src/**/__tests__/**"
	]
}
